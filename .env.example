# Backend environment template. Prefer copying the canonical file:
#   cp backend/.env.example backend/.env
# The API reads `backend/.env` when you start it from the `backend/` directory.
# Root `env.template` lists many optional keys; only names in `app.core.config.Settings`
# (plus BIOMARKER_DISABLE_RATE_LIMIT for SlowAPI) are loaded unless set in Docker/CI.

# Required in production (never use default in prod)
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false

# Database
DATABASE_URL=sqlite:///./biomarker_app.db

# SlowAPI: set to 0 (or false/no) so per-route limits stay active. Only 1/true/yes disables.
BIOMARKER_DISABLE_RATE_LIMIT=0
# Pytest sets BIOMARKER_DISABLE_RATE_LIMIT=1 automatically (disables limits for TestClient).

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# CORS (never use * when BIOMARKER_ENV=production — validation will fail)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional LLM
OPENAI_API_KEY=
# ENABLE_PUBMED_GROUNDING=false
# NCBI_EMAIL=your.email@institution.org
# NCBI_API_KEY=

# Federated API hardening (optional)
# FEDERATED_REQUIRE_API_KEY=false

# Strict startup checks
# BIOMARKER_ENV=production
# STRICT_CONFIG_CHECK=true
