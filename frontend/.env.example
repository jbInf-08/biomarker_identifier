# API base URL (optional; axios in src/services/api.js defaults to
# http://localhost:8000/api when unset).
# REACT_APP_API_URL=http://localhost:8000/api

# Set to 'true' to access the app without logging in (e.g. when backend is down).
# Only use for local development.
REACT_APP_DEV_BYPASS_AUTH=false

# CRA injects only variables prefixed with REACT_APP_ at build time.
# NODE_ENV is set automatically by react-scripts (development / production).
