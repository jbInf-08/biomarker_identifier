{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "categories:accessibility": ["warn", { "minScore": 0.75 }],
      "categories:best-practices": ["warn", { "minScore": 0.75 }]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
