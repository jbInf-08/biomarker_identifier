# Production Environment Configuration
# Copy this file to .env.prod and update with your production values

# Database Configuration
DATABASE_URL=postgresql://biomarker_user:secure_password@db-host:5432/biomarker_db
POSTGRES_DB=biomarker_db
POSTGRES_USER=biomarker_user
POSTGRES_PASSWORD=secure_password

# Redis Configuration
REDIS_URL=redis://redis-host:6379/0
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis_password

# Security Configuration
SECRET_KEY=very-secure-secret-key-256-bits-long
DEBUG=False
LOG_LEVEL=INFO
LOG_JSON=true
# SQLAlchemy pool (PostgreSQL): size × API workers should stay below DB max_connections
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Optional: include Celery worker inspect in GET /health/ready (adds latency)
HEALTH_CHECK_CELERY=false
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External API Keys
COSMIC_API_KEY=your_cosmic_api_key_here
ONCOKB_API_KEY=your_oncokb_api_key_here
PUBMED_API_KEY=your_pubmed_api_key_here

# Docker Configuration
BIOMARKER_DOCKER_USERNAME=your_docker_username

# Monitoring Configuration
GRAFANA_PASSWORD=secure_grafana_password

# File Storage Configuration
UPLOAD_DIR=/app/data/raw
PROCESSED_DIR=/app/data/processed
REPORTS_DIR=/app/reports
MODELS_DIR=/app/models
STATIC_DIR=/app/static
TEMP_DIR=/app/data/temp

# Analysis Configuration
MAX_FILE_SIZE=104857600  # 100MB
MAX_SAMPLES=1000
MAX_GENES=50000
DEFAULT_RANDOM_SEED=42

# Machine Learning Configuration
CV_FOLDS=5
STABILITY_BOOTSTRAPS=100
PERMUTATION_TESTS=100
FEATURE_SELECTION_THRESHOLD=0.6

# Preprocessing Configuration
MIN_VARIANCE_GENES=10000
MIN_EXPRESSION_THRESHOLD=1.0
MAX_MISSING_RATE=0.1
BATCH_CORRECTION_METHOD=combat

# Statistical Testing Configuration
FDR_METHOD=benjamini_hochberg
EFFECT_SIZE_METRIC=cohens_d

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/your-domain.com.crt
SSL_KEY_PATH=/etc/ssl/private/your-domain.com.key

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-west-2

# Email Configuration (for notifications)
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@your-domain.com
SMTP_PASSWORD=email_password
SMTP_USE_TLS=True

# Performance Configuration
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65
CLIENT_MAX_BODY_SIZE=100m

# Logging Configuration
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=json

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# Cache Configuration
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000

# Session Configuration
SESSION_TIMEOUT=1800  # 30 minutes
SESSION_CLEANUP_INTERVAL=300  # 5 minutes

# File Upload Configuration
UPLOAD_CHUNK_SIZE=8192
UPLOAD_MAX_FILES=10
UPLOAD_ALLOWED_EXTENSIONS=.csv,.tsv,.xlsx,.xls

# Analysis Configuration
ANALYSIS_TIMEOUT=3600  # 1 hour
ANALYSIS_MAX_CONCURRENT=5
ANALYSIS_QUEUE_SIZE=100

# Report Configuration
REPORT_TEMPLATE_DIR=/app/reports/templates
REPORT_OUTPUT_DIR=/app/reports/output
REPORT_CACHE_TTL=7200  # 2 hours

# Clinical Annotation Configuration
CLINICAL_ANNOTATION_TIMEOUT=300  # 5 minutes
CLINICAL_ANNOTATION_RETRY_COUNT=3
CLINICAL_ANNOTATION_CACHE_TTL=86400  # 24 hours

# Pathway Analysis Configuration
PATHWAY_ANALYSIS_TIMEOUT=600  # 10 minutes
PATHWAY_ANALYSIS_MAX_GENES=1000
PATHWAY_ANALYSIS_MIN_GENES=10

# WebSocket Configuration
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_HEARTBEAT_TIMEOUT=60
WEBSOCKET_MAX_CONNECTIONS=1000

# Celery Configuration
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_DISABLE_RATE_LIMITS=True
CELERY_RESULT_EXPIRES=3600

# Prometheus Configuration
BIOMARKER_PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# Grafana Configuration
BIOMARKER_GRAFANA_ENABLED=True
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=secure_grafana_password

# Alerting Configuration
ALERT_EMAIL_ENABLED=True
ALERT_EMAIL_RECIPIENTS=admin@your-domain.com,alerts@your-domain.com
ALERT_SLACK_ENABLED=False
ALERT_SLACK_WEBHOOK_URL=

# Maintenance Configuration
MAINTENANCE_MODE=False
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.

# Feature Flags
FEATURE_CLINICAL_ANNOTATION=True
FEATURE_PATHWAY_ANALYSIS=True
FEATURE_REPORT_GENERATION=True
FEATURE_REAL_TIME_UPDATES=True
FEATURE_USER_MANAGEMENT=True
FEATURE_API_DOCUMENTATION=True

# Development/Testing Flags (should be False in production)
ENABLE_DEBUG_TOOLBAR=False
ENABLE_PROFILING=False
ENABLE_TEST_ENDPOINTS=False
ENABLE_MOCK_DATA=False
