# Copy to `.env` in this directory for local development:
#   cp .env.example .env
# Pydantic loads `env_file=".env"` relative to the process working directory — run the API
# from `backend/` (e.g. `uvicorn app.main:app`) so this file is picked up.
# See repository README "Configuration" for every variable `Settings` accepts.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

DATABASE_URL=sqlite:///./biomarker_app.db

# SQLAlchemy pool (PostgreSQL only)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

BIOMARKER_DISABLE_RATE_LIMIT=0

OPENAI_API_KEY=
# COSMIC (Sanger): HTTP Basic auth — account email + password/API secret
COSMIC_API_EMAIL=
COSMIC_API_KEY=
# OncoKB Bearer token (alias: ONCOKB_API_TOKEN)
ONCOKB_API_KEY=
# Optional: Kaggle REST for kaggle_collector (otherwise OpenML)
# KAGGLE_USERNAME=
# KAGGLE_KEY=
PUBMED_API_KEY=
HUGGINGFACE_HUB_TOKEN=

ENABLE_PUBMED_GROUNDING=false
NCBI_EMAIL=
NCBI_API_KEY=

FEDERATED_REQUIRE_API_KEY=false
# Reserved for Bonawitz-style secure aggregation (not implemented server-side yet)
# FEDERATED_CRYPTO_SECURE_AGGREGATION_ENABLED=false

# Raw counts + DESeq2/edgeR (requires R + pip install -r requirements-optional-deseq2.txt)
# ANALYSIS_ENABLE_RAW_COUNTS_DESEQ2=false

# When true, users with tenant_id must send matching X-Tenant-ID on API requests
# MULTI_TENANT_ENFORCE=false

# Optional region label for health/status (multi-region deployments)
# DEPLOYMENT_REGION=

# Optional ML features (disable on slim images without PyTorch)
# ML_ENABLE_FOCAL_LOSS=true
# ML_ENABLE_SHALLOW_GCN=true
# Planned deeper GNN stage (beyond shallow GCN)
# ML_ENABLE_DEEP_GNN_STAGE=false

# BASE_URL=http://localhost:8000
# LOG_JSON=false
# HEALTH_CHECK_CELERY=false
# BIOMARKER_ENV=production
# STRICT_CONFIG_CHECK=true
